PORT=3001
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashScope base URL（一般不需要改）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型（默认 qwen-plus）
# QWEN_MODEL=qwen-plus

# AI 接口鉴权 Key（设置后前端需在 Authorization: Bearer <key> 头中携带）
# 留空则 AI 接口对所有来源开放（仅限本地验证）
# INTERNAL_API_KEY=

# CORS 允许的来源，逗号分隔（默认 localhost:5173）
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI 采样上限（可选，覆盖默认值）
# AI_CLASSIFY_MAX=20
# AI_SUMMARIZE_SAMPLE=30
# AI_SUGGESTIONS_MIN_RECORDS=10
